# ================================
# ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in the values
# cp .env.example .env
# ================================

# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/madrasha_db

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=your_access_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Secret (generate with: openssl rand -hex 32)
COOKIE_SECRET=your_cookie_secret_at_least_32_characters_long

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://www.madrasadarularqam.org

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=15

# File Uploads
UPLOAD_DIR=./uploads
UPLOAD_LIMIT=52428800

# Admin Seeder (used by prisma/seed.ts)
ADMIN_PASSWORD=Admin@123456
