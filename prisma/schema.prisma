// Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

// ================================
// ENUMS
// ================================

enum Role {
    ADMIN
    USER
}

enum MediaType {
    IMAGE
    VIDEO
}

// ================================
// MODELS
// ================================

model User {
    id       String  @id @default(cuid())
    email    String  @unique
    password String
    name     String
    role     Role    @default(USER)
    isActive Boolean @default(true)

    // Refresh tokens (one user can have multiple sessions)
    refreshTokens RefreshToken[]

    // Galleries uploaded by this user
    galleries Gallery[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}

model RefreshToken {
    id        String   @id @default(cuid())
    token     String   @unique
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    createdAt DateTime @default(now())

    @@map("refresh_tokens")
}

model Gallery {
    id          String    @id @default(cuid())
    title       String
    description String?
    imageUrl    String?
    videoUrl    String?
    mediaType   MediaType @default(IMAGE)
    category    String    @default("general")
    featured    Boolean   @default(false)
    uploadedBy  String?
    uploader    User?     @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("galleries")
}

model Notice {
    id       String  @id @default(cuid())
    title    String
    content  String
    category String  @default("general")
    featured Boolean @default(false)
    slug     String  @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("notices")
}

model HomePage {
    id         String @id @default(cuid())
    heroSlides Json   @default("[]")
    stats      Json   @default("[]")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("home_pages")
}
