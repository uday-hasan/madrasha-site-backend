// Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

// ================================
// ENUMS
// ================================

enum Role {
    ADMIN
    USER
}

enum MediaType {
    IMAGE
    VIDEO
}

enum QuestionStatus {
    DRAFT
    PUBLISHED
}

enum AuthorRole {
    ADMIN
    TEACHER
    USER
}

enum ApplicationStatus {
    PENDING
    APPROVED
    REJECTED
}

enum PaymentMethod {
    ONLINE
    CASH
}

enum PaymentStatus {
    PENDING
    COMPLETED
    FAILED
}

// ================================
// MODELS
// ================================

model User {
    id       String  @id @default(cuid())
    email    String  @unique
    password String
    name     String
    role     Role    @default(USER)
    isActive Boolean @default(true)

    // Refresh tokens (one user can have multiple sessions)
    refreshTokens RefreshToken[]

    // Galleries uploaded by this user
    galleries Gallery[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}

model RefreshToken {
    id        String   @id @default(cuid())
    token     String   @unique
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    createdAt DateTime @default(now())

    @@map("refresh_tokens")
}

model Gallery {
    id          String    @id @default(cuid())
    title       String
    description String?
    imageUrl    String?
    videoUrl    String?
    mediaType   MediaType @default(IMAGE)
    category    String    @default("general")
    featured    Boolean   @default(false)
    uploadedBy  String?
    uploader    User?     @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("galleries")
}

model Notice {
    id            String  @id @default(cuid())
    title         String
    content       String  @db.Text
    excerpt       String? @db.Text
    category      String  @default("general")
    featured      Boolean @default(false)
    isActive      Boolean @default(true)
    isImportant   Boolean @default(false)
    attachmentUrl String?
    slug          String  @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("notices")
}

model HomePage {
    id         String @id @default(cuid())
    heroSlides Json   @default("[]")
    stats      Json   @default("[]")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("home_pages")
}

model DonationPage {
    id                 String @id @default(cuid())
    pageTitle          String @default("মাদরাসায় দান করুন")
    pageDescription    String @default("আপনার দান মাদরাসার উন্নয়নে সহায়তা করবে")
    bannerText         String @default("মাদরাসায় দান করুন")
    quranicVerse       Json   @default("{\"arabic\": \"\", \"bangla\": \"\", \"reference\": \"\"}")
    categories         Json   @default("[]")
    methods            Json   @default("[]")
    contactForDonation Json   @default("{\"phone\": \"\", \"email\": \"\", \"note\": \"\"}")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("donation_pages")
}

model ContactPage {
    id            String   @id @default(cuid())
    address       String
    city          String
    district      String
    phone         String[] @default([])
    email         String[] @default([])
    officeHours   String
    googleMapsUrl String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("contact_pages")
}

model Department {
    id            String   @id @default(cuid())
    name          String
    slug          String   @unique
    description   String   @db.Text
    duration      String
    subjects      String[] @default([])
    headTeacher   String?
    totalStudents Int      @default(0)
    imageUrl      String?
    isActive      Boolean  @default(true)
    displayOrder  Int      @default(0)

    // Admission requirements for this department
    admissionRequirements AdmissionRequirement[]

    // Student applications for this department
    studentApplications StudentApplication[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("departments")
}

model SiteSettings {
    id          String  @id @default(cuid())
    key         String  @unique
    value       String  @db.Text
    category    String  @default("general")
    description String?
    isPublic    Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("site_settings")
}

model Teacher {
    id           String  @id @default(cuid())
    name         String
    designation  String
    department   String?
    education    String?
    experience   String?
    photoUrl     String?
    bio          String? @db.Text
    phone        String?
    email        String?
    isActive     Boolean @default(true)
    displayOrder Int     @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("teachers")
}

model Question {
    id         String         @id @default(cuid())
    question   String         @db.Text
    category   String
    authorName String
    status     QuestionStatus @default(DRAFT)
    isResolved Boolean        @default(false)
    answers    Answer[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("questions")
}

model Answer {
    id         String     @id @default(cuid())
    content    String     @db.Text
    authorName String
    authorRole AuthorRole @default(ADMIN)
    question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
    questionId String
    replies    Reply[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("answers")
}

model Reply {
    id         String     @id @default(cuid())
    content    String     @db.Text
    authorName String
    authorRole AuthorRole @default(USER)
    answer     Answer     @relation(fields: [answerId], references: [id], onDelete: Cascade)
    answerId   String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("replies")
}

// ================================
// ABOUT PAGE MODELS
// ================================

model AboutSection {
    id           String  @id @default(cuid())
    title        String // e.g., আবেদন, আমাদের লক্ষ্য ও উদ্দেশ্য, অবতরণিকা
    slug         String  @unique
    description  String  @db.Text
    displayOrder Int     @default(0)
    isActive     Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("about_sections")
}

model AboutValue {
    id           String  @id @default(cuid())
    title        String // e.g., ইলম, আমল, আখলাক
    description  String  @db.Text // shown in modal
    icon         String? // emoji or icon identifier
    displayOrder Int     @default(0)
    isActive     Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("about_values")
}

model Achievement {
    id           String  @id @default(cuid())
    year         String
    title        String
    description  String  @db.Text
    displayOrder Int     @default(0)
    isActive     Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("achievements")
}

model ProposedBuilding {
    id            String  @id @default(cuid())
    title         String
    imageUrl      String?
    status        String  @default("Planning") // Planning, Under Construction, Completed
    estimatedCost String?
    description   String? @db.Text
    displayOrder  Int     @default(0)
    isActive      Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("proposed_buildings")
}

model Leadership {
    id           String  @id @default(cuid())
    name         String
    designation  String
    photoUrl     String?
    bio          String? @db.Text
    email        String?
    phone        String?
    displayOrder Int     @default(0)
    isActive     Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("leadership")
}

model AboutQuote {
    id           String  @id @default(cuid())
    quote        String  @db.Text
    author       String
    authorRole   String  @default("Founder") // Founder, Teacher, etc.
    displayOrder Int     @default(0)
    isActive     Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("about_quotes")
}

// ================================
// ADMISSION PAGE MODELS
// ================================

model AdmissionSettings {
    id               String  @id @default(cuid())
    isOpen           Boolean @default(true)
    session          String  @default("২০২৫-২০২৬") // e.g., "২০২৫-२०२६"
    startDate        String  @default("২০২৫ সালের ১ জানুয়ারি")
    endDate          String  @default("२०२५ সালের ३१ মার্চ")
    officeHoursStart String  @default("সকাল ৮টা")
    officeHoursEnd   String  @default("বিকেল ৪টা")
    officeHoursDays  String  @default("শনি - বৃহস্পতি")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("admission_settings")
}

model AdmissionProcess {
    id           String  @id @default(cuid())
    step         String  @db.Text // Each step of the admission process
    displayOrder Int     @default(0)
    isActive     Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("admission_processes")
}

model AdmissionRequirement {
    id                   String     @id @default(cuid())
    departmentId         String
    department           Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
    minimumAge           String // e.g., "৪-৭ বছর"
    minimumQualification String     @db.Text // e.g., "কোনো পূর্ব যোগ্যতার প্রয়োজন নেই"
    documents            String[]   @default([]) // e.g., ["জন্মনিবন্ধন সনদ", "পাসপোর্ট সাইজ ছবি ২ কপি"]
    fees                 String // e.g., "মাসিক ৫০০ টাকা"
    seats                Int        @default(0)
    displayOrder         Int        @default(0)
    isActive             Boolean    @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("admission_requirements")
}

model AdmissionImportantDate {
    id           String  @id @default(cuid())
    event        String // e.g., "ভর্তি ফরম বিতরণ শুরু"
    date         String // e.g., "১ জানুয়ারি २०२५"
    displayOrder Int     @default(0)
    isActive     Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("admission_important_dates")
}

// ================================
// STUDENT APPLICATION MODELS
// ================================

model StudentApplication {
    id               String     @id @default(cuid())
    studentName      String
    studentEmail     String
    studentPhone     String
    fatherName       String
    fatherPhone      String
    dateOfBirth      String
    presentAddress   String
    permanentAddress String
    departmentId     String
    department       Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

    // Application details
    status        ApplicationStatus @default(PENDING)
    paymentMethod PaymentMethod
    notes         String?           @db.Text

    // Relations
    payments ApplicationPayment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("student_applications")
}

model ApplicationPayment {
    id            String             @id @default(cuid())
    applicationId String
    application   StudentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

    // Payment details
    amount        Float
    paymentMethod PaymentMethod
    status        PaymentStatus @default(PENDING)
    transactionId String?       @unique

    // For online payments (will be populated later)
    paymentGateway String? // e.g., "stripe", "bkash", "nagad"
    metadata       Json? // Additional payment data

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("application_payments")
}
