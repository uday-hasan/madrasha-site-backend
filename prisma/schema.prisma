// Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

// ================================
// ENUMS
// ================================

enum Role {
    ADMIN
    USER
}

enum MediaType {
    IMAGE
    VIDEO
}

enum QuestionStatus {
    DRAFT
    PUBLISHED
}

enum AuthorRole {
    ADMIN
    TEACHER
    USER
}

// ================================
// MODELS
// ================================

model User {
    id       String  @id @default(cuid())
    email    String  @unique
    password String
    name     String
    role     Role    @default(USER)
    isActive Boolean @default(true)

    // Refresh tokens (one user can have multiple sessions)
    refreshTokens RefreshToken[]

    // Galleries uploaded by this user
    galleries Gallery[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}

model RefreshToken {
    id        String   @id @default(cuid())
    token     String   @unique
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    createdAt DateTime @default(now())

    @@map("refresh_tokens")
}

model Gallery {
    id          String    @id @default(cuid())
    title       String
    description String?
    imageUrl    String?
    videoUrl    String?
    mediaType   MediaType @default(IMAGE)
    category    String    @default("general")
    featured    Boolean   @default(false)
    uploadedBy  String?
    uploader    User?     @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("galleries")
}

model Notice {
    id            String  @id @default(cuid())
    title         String
    content       String  @db.Text
    excerpt       String? @db.Text
    category      String  @default("general")
    featured      Boolean @default(false)
    isActive      Boolean @default(true)
    isImportant   Boolean @default(false)
    attachmentUrl String?
    slug          String  @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("notices")
}

model HomePage {
    id         String @id @default(cuid())
    heroSlides Json   @default("[]")
    stats      Json   @default("[]")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("home_pages")
}

model DonationPage {
    id                 String @id @default(cuid())
    pageTitle          String @default("মাদরাসায় দান করুন")
    pageDescription    String @default("আপনার দান মাদরাসার উন্নয়নে সহায়তা করবে")
    bannerText         String @default("মাদরাসায় দান করুন")
    quranicVerse       Json   @default("{\"arabic\": \"\", \"bangla\": \"\", \"reference\": \"\"}")
    categories         Json   @default("[]")
    methods            Json   @default("[]")
    contactForDonation Json   @default("{\"phone\": \"\", \"email\": \"\", \"note\": \"\"}")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("donation_pages")
}

model ContactPage {
    id            String   @id @default(cuid())
    address       String
    city          String
    district      String
    phone         String[] @default([])
    email         String[] @default([])
    officeHours   String
    googleMapsUrl String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("contact_pages")
}

model Department {
    id            String   @id @default(cuid())
    name          String
    slug          String   @unique
    description   String   @db.Text
    duration      String
    subjects      String[] @default([])
    headTeacher   String?
    totalStudents Int      @default(0)
    imageUrl      String?
    isActive      Boolean  @default(true)
    displayOrder  Int      @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("departments")
}

model SiteSettings {
    id          String  @id @default(cuid())
    key         String  @unique
    value       String  @db.Text
    category    String  @default("general")
    description String?
    isPublic    Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("site_settings")
}

model Teacher {
    id           String  @id @default(cuid())
    name         String
    designation  String
    department   String?
    education    String?
    experience   String?
    photoUrl     String?
    bio          String? @db.Text
    phone        String?
    email        String?
    isActive     Boolean @default(true)
    displayOrder Int     @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("teachers")
}

model Question {
    id         String         @id @default(cuid())
    question   String         @db.Text
    category   String
    authorName String
    status     QuestionStatus @default(DRAFT)
    isResolved Boolean        @default(false)
    answers    Answer[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("questions")
}

model Answer {
    id         String     @id @default(cuid())
    content    String     @db.Text
    authorName String
    authorRole AuthorRole @default(ADMIN)
    question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
    questionId String
    replies    Reply[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("answers")
}

model Reply {
    id         String     @id @default(cuid())
    content    String     @db.Text
    authorName String
    authorRole AuthorRole @default(USER)
    answer     Answer     @relation(fields: [answerId], references: [id], onDelete: Cascade)
    answerId   String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("replies")
}
